# ---------------------------------------------
# AI Resume Grader - root .gitignore
# ---------------------------------------------

# Dependencies
node_modules/
**/node_modules/
.pnp/
.pnp.js

# Environment variables / secrets
.env
.env.*
!.env.example
**/.env
**/.env.*
!**/.env.example

# Build output
dist/
build/
**/dist/
**/build/
.vite/

# Uploaded / temporary resume files
uploads/
**/uploads/
tmp/
temp/

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
logs/

# Caches
.cache/
.npm/
.eslintcache
*.tsbuildinfo

# Coverage / test output
coverage/
*.lcov

# Editor / IDE
.vscode/
.idea/
*.swp
*.swo

# OS files
.DS_Store
Thumbs.db
desktop.ini

# Optional package manager lock files for the other managers
yarn.lock
pnpm-lock.yaml
