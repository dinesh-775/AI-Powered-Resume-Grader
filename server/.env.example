# Server
PORT=5000
CLIENT_ORIGIN=http://localhost:5173

# MongoDB (local or Atlas)
MONGODB_URI=mongodb://127.0.0.1:27017/ai-resume-grader

# JWT
JWT_SECRET=replace_with_a_long_random_secret
JWT_EXPIRES_IN=7d

# Google Gemini (Google AI Studio). Get a key: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Cloudinary (for authenticated users' resume file storage)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
